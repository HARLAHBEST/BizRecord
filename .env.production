# ============================================
# BizRecord Production Environment Variables
# ============================================
# DO NOT COMMIT THIS FILE TO GIT
# Add to .gitignore: .env.production

# ============================================
# Application Environment
# ============================================
APP_ENV=production

# ============================================
# API Configuration
# ============================================
# Production API URL (Required)
EXPO_PUBLIC_API_URL_PRODUCTION=https://bizrecord.tech

# Staging API URL (Optional - for testing before production)
EXPO_PUBLIC_API_URL_STAGING=https://staging.bizrecord.tech

# ============================================
# Android Configuration
# ============================================
# Must match Google Play Console package name
EXPO_PUBLIC_ANDROID_PACKAGE=com.bizrecord.inventory

# ============================================
# Subscription Plans (from Google Play Console)
# ============================================
# Basic Plan - Monthly
EXPO_PUBLIC_BILLING_SKU_BASIC_MONTHLY=bizrecord_basic_monthly

# Basic Plan - Yearly
EXPO_PUBLIC_BILLING_SKU_BASIC_YEARLY=bizrecord_basic_yearly

# Pro Plan - Monthly
EXPO_PUBLIC_BILLING_SKU_PRO_MONTHLY=bizrecord_pro_monthly

# Pro Plan - Yearly
EXPO_PUBLIC_BILLING_SKU_PRO_YEARLY=bizrecord_pro_yearly

# ============================================
# Add-ons (from Google Play Console)
# ============================================
# Workspace Slots Add-on - Monthly
EXPO_PUBLIC_BILLING_SKU_ADDON_WORKSPACE_MONTHLY=bizrecord_addon_workspace_monthly

# Workspace Slots Add-on - Yearly
EXPO_PUBLIC_BILLING_SKU_ADDON_WORKSPACE_YEARLY=bizrecord_addon_workspace_yearly

# Staff Seat Add-on - Monthly
EXPO_PUBLIC_BILLING_SKU_ADDON_STAFF_MONTHLY=bizrecord_addon_staff_monthly

# Staff Seat Add-on - Yearly
EXPO_PUBLIC_BILLING_SKU_ADDON_STAFF_YEARLY=bizrecord_addon_staff_yearly

# WhatsApp Bundle (100 messages) - Monthly
EXPO_PUBLIC_BILLING_SKU_ADDON_WHATSAPP100_MONTHLY=bizrecord_addon_whatsapp100_monthly

# WhatsApp Bundle (100 messages) - Yearly
EXPO_PUBLIC_BILLING_SKU_ADDON_WHATSAPP100_YEARLY=bizrecord_addon_whatsapp100_yearly
